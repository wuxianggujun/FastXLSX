# Build directories
/build/
/build-*/
/cmake-build-*/
/out/
/dist/
/%OPC_BUILD%/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
DartConfiguration.tcl
Testing/
vcpkg_installed/

# CMake local user presets
/CMakeUserPresets.json

# IDE and editor files
/.idea/
/.vscode/
/.vs/
*.user
*.suo
*.vcxproj.user

# Binary and object files
*.exe
*.dll
*.lib
*.pdb
*.ilk
*.obj
*.o
*.a
*.so
*.dylib

# Logs and temporary files
*.log
*.tmp
*.temp

# Local build/verify helper scripts (not part of the build system)
/fx_*.bat

# Python generated files
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated example/benchmark workbooks
/fastxlsx-bench-*.json

# Stray test artifacts (tests normally write to the system temp dir; this
# guards against accidental root output when an executable is run directly).
/fastxlsx-*.xlsx
/fastxlsx-*.png
/fastxlsx-*.jpg
/fastxlsx-*.gif
/fastxlsx-*.bin
/invalid-*.xlsx

# Environment and local secret files
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Local/private agent or tool state
/.ace-tool/
/.codex/
/.claude/
/.cursor/
/.cache/
/.local/
